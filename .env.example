# Скопируйте в .env и заполните. Файл .env не коммитить в репозиторий.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Имя бота без @ (например MyMatrixBot) — для реферальной ссылки t.me/MyMatrixBot?start=...
TELEGRAM_BOT_USERNAME=

# URL вашего веб-приложения (HTTPS). Для локальной разработки — например ngrok: https://xxxx.ngrok.io
WEBAPP_BASE_URL=https://your-domain.com

# Секрет для вызова /api/bot/on-start (бот передаёт в заголовке X-Bot-Secret). Придумайте длинную случайную строку.
BOT_ON_START_SECRET=

# Telegram ID пользователя, которому разрешена регистрация без реферальной ссылки (только этот пользователь может нажать /start без перехода по ссылке). На Railway добавить в Variables.
# ALLOWED_REGISTER_WITHOUT_REF_TELEGRAM_ID=123456789

# CryptoCloud — тестовый режим (постоянная страница оплаты). Укажите ОДНО:
# Вариант 1: полная ссылка из ЛК CryptoCloud
CRYPTOCLOUD_POS_LINK=https://pay.cryptocloud.plus/pos/nHFyGCeofCdjbV32
# Вариант 2: только id страницы (ссылку соберём сами)
# CRYPTOCLOUD_POS_ID=nHFyGCeofCdjbV32
# Для продакшена (создание инвойсов через API)
CRYPTOCLOUD_API_KEY=
CRYPTOCLOUD_SHOP_ID=
CRYPTOCLOUD_SECRET=
