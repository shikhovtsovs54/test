# Скопируйте в .env и заполните. Файл .env не коммитить в репозиторий.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Имя бота без @ (например MyMatrixBot) — для реферальной ссылки t.me/MyMatrixBot?start=...
TELEGRAM_BOT_USERNAME=

# URL вашего веб-приложения (HTTPS). Для локальной разработки — например ngrok: https://xxxx.ngrok.io
WEBAPP_BASE_URL=https://your-domain.com

# Секрет для вызова /api/bot/on-start (бот передаёт в заголовке X-Bot-Secret). Придумайте длинную случайную строку.
BOT_ON_START_SECRET=

# CryptoCloud (тестовый режим — постоянная страница оплаты)
# Ссылка из личного кабинета: «Ссылка на постоянную страницу оплаты»
CRYPTOCLOUD_POS_LINK=https://pay.cryptocloud.plus/pos/nHFyGCeofCdjbV32
# Для выхода из тестового режима — API создание инвойсов (опционально)
CRYPTOCLOUD_API_KEY=
CRYPTOCLOUD_SHOP_ID=
CRYPTOCLOUD_SECRET=
